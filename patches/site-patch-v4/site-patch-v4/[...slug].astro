---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const sessoes = await getCollection('sessoes');
  return sessoes.map(sessao => ({
    params: { slug: sessao.slug },
    props: { sessao },
  }));
}

const { sessao } = Astro.props;
const { Content } = await sessao.render();
const data = sessao.data;

const formatarData = (d: Date) => {
  const meses = ['janeiro', 'fevereiro', 'março', 'abril', 'maio', 'junho', 'julho', 'agosto', 'setembro', 'outubro', 'novembro', 'dezembro'];
  return `${d.getDate()} ${meses[d.getMonth()]} ${d.getFullYear()}`;
};

// Caminhos para os ficheiros raw publicados em public/sessoes/<slug>/
const reportPath = `/sessoes/${sessao.slug}/report.md`;
const transcriptPath = `/sessoes/${sessao.slug}/transcript.json`;
---

<Base title={`${data.titulo} — Governo AI`} description={data.sumario}>
  <article class="session-container">
    <header class="session-header">
      <div class="session-meta">
        <span><strong>Sessão #{String(data.numero).padStart(2, '0')}</strong></span>
        <span>{formatarData(data.data)}</span>
        <span>Tema: {data.tema}</span>
      </div>

      <h1 class="session-title">{data.titulo}</h1>

      <p class="session-lead">{data.sumario}</p>
    </header>

    <div class="session-body">
      <Content />
    </div>

    <aside class="downloads">
      <div class="downloads-header">
        <h3>Material da sessão</h3>
        <p>Os ficheiros gerados pela simulação, disponíveis para análise, citação ou investigação. Conteúdo idêntico ao publicado nesta página.</p>
      </div>
      <div class="downloads-list">
        <a href={reportPath} download class="download-item">
          <div class="download-icon">md</div>
          <div class="download-text">
            <div class="download-title">Relatório completo</div>
            <div class="download-desc">Versão markdown deste documento, tal como saiu do orquestrador.</div>
          </div>
        </a>
        <a href={transcriptPath} download class="download-item">
          <div class="download-icon">json</div>
          <div class="download-text">
            <div class="download-title">Transcrição do debate</div>
            <div class="download-desc">Todas as intervenções dos agentes e do moderador, fase a fase, em JSON.</div>
          </div>
        </a>
      </div>
    </aside>

    <div class="session-footer-disclaimer">
      Esta é uma simulação com agentes de IA representando posições partidárias com base em programas, declarações públicas e histórico de votação. Os resultados não correspondem a posições oficiais nem preveem o desfecho real. {data.quinzenal_link && (
        <span>Para acompanhar a discussão real, ver <a href={data.quinzenal_link} target="_blank" rel="noopener">a quinzenal correspondente</a>.</span>
      )}
    </div>
  </article>
</Base>

<style>
.session-container {
  max-width: 760px;
  margin: 0 auto;
  padding: 3rem 2rem 6rem;
}

.session-header {
  margin-bottom: 3rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--border);
}

.session-meta {
  font-family: var(--mono);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  display: flex;
  gap: 1.5rem;
  align-items: center;
  flex-wrap: wrap;
}

.session-meta strong { color: var(--accent); font-weight: 500; }

.session-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 4vw, 2.75rem);
  line-height: 1.15;
  font-weight: 500;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}

.session-lead {
  font-family: var(--serif);
  font-size: 1.25rem;
  line-height: 1.55;
  color: var(--text-muted);
  font-style: italic;
  font-weight: 300;
}

.session-body :global(h2) {
  font-family: var(--serif);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--accent);
  margin: 3rem 0 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.session-body :global(h3) {
  font-family: var(--serif);
  font-size: 1.4rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin: 2rem 0 1rem;
}

.session-body :global(p) {
  font-family: var(--serif);
  font-size: 1.0625rem;
  line-height: 1.75;
  margin-bottom: 1rem;
  color: var(--text);
}

.session-body :global(strong) {
  font-weight: 600;
}

.session-body :global(em) {
  color: var(--text-muted);
  font-style: italic;
}

.session-body :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-family: var(--serif);
}

.session-body :global(table tr) {
  border-bottom: 1px solid var(--border);
}

.session-body :global(table th) {
  text-align: left;
  padding: 0.75rem 1rem 0.75rem 0;
  font-family: var(--mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  font-weight: 500;
}

.session-body :global(table td) {
  padding: 1rem 1rem 1rem 0;
  vertical-align: top;
  font-size: 1rem;
  line-height: 1.5;
}

.session-body :global(table td:first-child) {
  width: 140px;
  font-family: var(--mono);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.session-body :global(ul) {
  margin: 1rem 0 1.5rem 1.5rem;
}

.session-body :global(li) {
  font-family: var(--serif);
  font-size: 1.0625rem;
  line-height: 1.7;
  margin-bottom: 0.5rem;
}

.session-body :global(blockquote) {
  border-left: 3px solid var(--accent);
  padding-left: 1.5rem;
  margin: 1.5rem 0;
  font-style: italic;
  color: var(--text-muted);
}

/* ============ DOWNLOADS ============ */
.downloads {
  margin-top: 4rem;
  padding-top: 2.5rem;
  border-top: 1px solid var(--border);
}

.downloads-header {
  margin-bottom: 1.5rem;
}

.downloads-header h3 {
  font-family: var(--mono);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  font-weight: 500;
  margin-bottom: 0.6rem;
}

.downloads-header p {
  font-family: var(--serif);
  font-size: 0.95rem;
  line-height: 1.55;
  color: var(--text-muted);
  font-style: italic;
  max-width: 560px;
}

.downloads-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.download-item {
  display: flex;
  gap: 1rem;
  align-items: center;
  padding: 1rem 1.25rem;
  background: #FCFCF9;
  border: 1px solid var(--border);
  border-radius: 2px;
  color: var(--text);
  text-decoration: none;
  transition: all 0.15s;
}

.download-item:hover {
  background: #F5F5EE;
  border-color: var(--border-strong);
  transform: translateY(-1px);
}

.download-icon {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent);
  background: #FFFFFF;
  border: 1px solid var(--border-strong);
  padding: 0.4rem 0.5rem;
  border-radius: 2px;
  min-width: 38px;
  text-align: center;
  flex-shrink: 0;
}

.download-text {
  flex: 1;
  min-width: 0;
}

.download-title {
  font-family: var(--serif);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 0.15rem;
}

.download-desc {
  font-family: var(--serif);
  font-size: 0.8rem;
  color: var(--text-muted);
  line-height: 1.35;
}

.session-footer-disclaimer {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
  font-size: 0.85rem;
  color: var(--text-muted);
  font-style: italic;
  line-height: 1.6;
}

.session-footer-disclaimer a {
  color: var(--accent);
  text-decoration: underline;
}

@media (max-width: 640px) {
  .downloads-list { grid-template-columns: 1fr; }
}
</style>
