---
import Base from '../layouts/Base.astro';
import SessaoDestaque from '../components/SessaoDestaque.astro';
import { getCollection } from 'astro:content';

const todasSessoes = await getCollection('sessoes');
const sessoesOrdenadas = todasSessoes.sort((a, b) =>
  b.data.data.valueOf() - a.data.data.valueOf()
);

const sessaoDestaque = sessoesOrdenadas[0];
const sessoesAnteriores = sessoesOrdenadas.slice(1);

const formatarData = (d: Date) => {
  const meses = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
  return `${d.getDate()} ${meses[d.getMonth()]} ${d.getFullYear()}`;
};
---

<Base activePage="sessoes">
  <section class="hero">
    <div class="hero-tag">Simulação · Quinzenal · Não-partidário</div>
    <h1 class="hero-title">Os partidos negoceiam. A inteligência artificial dá-lhes voz.</h1>
    <p class="hero-description">A cada quinze dias, agentes que representam os partidos com assento parlamentar debatem o tema da quinzenal seguinte. Três cenários: o acordo provável, o ideal hipotético, e o impasse.</p>
  </section>

  {sessaoDestaque && (
    <section class="featured">
      <div class="section-label">Sessão mais recente</div>
      <SessaoDestaque sessao={sessaoDestaque} />
    </section>
  )}

  {sessoesAnteriores.length > 0 && (
    <section class="archive">
      <div class="section-label">Sessões anteriores</div>
      <ul class="archive-list">
        {sessoesAnteriores.map(s => (
          <li class="archive-item">
            <a href={`/sessoes/${s.id}`} class="archive-link">
              <div class="archive-date">{formatarData(s.data.data)}</div>
              <div class="archive-content">
                <h3>{s.data.titulo}</h3>
                <p>{s.data.sumario}</p>
              </div>
              <div class="archive-tags">
                <span class="tag">{s.data.tema}</span>
                {s.data.desfecho === 'acordo-provavel' && <span class="tag outcome-acordo">Acordo provável</span>}
                {s.data.desfecho === 'impasse' && <span class="tag outcome-impasse">Impasse</span>}
                {s.data.desfecho === 'maxima-ambicao' && <span class="tag outcome-ambicao">Máxima ambição</span>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {sessoesAnteriores.length === 0 && sessaoDestaque && (
    <section class="archive">
      <div class="section-label">Sessões anteriores</div>
      <p class="empty-state">Esta é a primeira sessão. Mais virão a cada quinze dias.</p>
    </section>
  )}

  {!sessaoDestaque && (
    <section class="featured">
      <div class="empty-card">
        <h2>Em preparação</h2>
        <p>A primeira sessão estará disponível em breve. Subscreve para seres notificado.</p>
      </div>
    </section>
  )}
</Base>

<style>
.hero {
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 2rem 3rem;
  border-bottom: 1px solid var(--border);
}

.hero-tag {
  font-family: var(--mono);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}

.hero-title {
  font-family: var(--serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: 1.1;
  font-weight: 500;
  letter-spacing: -0.02em;
  max-width: 900px;
  margin-bottom: 1.5rem;
}

.hero-description {
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 300;
  line-height: 1.5;
  color: var(--text-muted);
  max-width: 720px;
  font-style: italic;
}

.featured {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3rem 2rem;
}

.section-label {
  font-family: var(--mono);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

.archive {
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 2rem 6rem;
}

.archive-list {
  list-style: none;
  border-top: 1px solid var(--border);
}

.archive-item {
  border-bottom: 1px solid var(--border);
}

.archive-link {
  display: grid;
  grid-template-columns: 100px 1fr auto;
  gap: 2rem;
  padding: 2rem 0;
  align-items: baseline;
  transition: padding 0.2s;
}

.archive-link:hover {
  padding-left: 1rem;
}

.archive-date {
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.archive-content h3 {
  font-family: var(--serif);
  font-size: 1.4rem;
  font-weight: 500;
  letter-spacing: -0.01em;
  margin-bottom: 0.5rem;
  line-height: 1.25;
}

.archive-content p {
  font-size: 0.9rem;
  color: var(--text-muted);
  max-width: 600px;
}

.archive-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.tag {
  font-family: var(--mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.25rem 0.6rem;
  background: var(--bg);
  border: 1px solid var(--border-strong);
  border-radius: 2px;
  color: var(--text-muted);
}

.tag.outcome-acordo { color: #2D5016; border-color: #C5D5B5; background: #F0F5EA; }
.tag.outcome-impasse { color: #6B2C00; border-color: #E5C5A8; background: #FAEFE3; }
.tag.outcome-ambicao { color: #6B5614; border-color: #E8D5A0; background: #FFF8E8; }

.empty-state {
  font-family: var(--serif);
  font-size: 1.1rem;
  color: var(--text-muted);
  font-style: italic;
  padding: 2rem 0;
}

.empty-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 4rem 3rem;
  text-align: center;
  border-radius: 4px;
}

.empty-card h2 {
  font-family: var(--serif);
  font-size: 1.75rem;
  margin-bottom: 1rem;
}

.empty-card p {
  font-family: var(--serif);
  color: var(--text-muted);
}

@media (max-width: 768px) {
  .archive-link { grid-template-columns: 1fr; gap: 0.5rem; }
}
</style>
